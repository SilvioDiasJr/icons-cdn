{
  "name": "@silviodiasjr/icons-native",
  "version": "0.2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SilvioDiasJr/icons-cdn.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react-native,react-native-svg",
    "prepare": "tsup src/index.ts --format cjs,esm --dts --clean --external react-native,react-native-svg",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react-native,react-native-svg",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@silviodiasjr/icons-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "react-native-svg": ">=14"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-native": "^0.73",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}